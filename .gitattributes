# Default text normalization
* text=auto eol=lf

# code files
*.cs      text eol=lf
*.csproj  text eol=lf
*.sln     text eol=lf
*.slnx    text eol=lf
*.props   text eol=lf
*.targets text eol=lf
*.js      text eol=lf
*.jsx     text eol=lf
*.ts      text eol=lf
*.tsx     text eol=lf

# JSON/YAML
*.json    text eol=lf
*.yml     text eol=lf
*.yaml    text eol=lf

# Scripts
*.sh      text eol=lf
*.ps1     text eol=crlf

# Windows-specific files
*.bat    text eol=crlf
*.cmd    text eol=crlf

# Binary files
*.png    binary
*.jpg    binary
*.zip    binary
